{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability allowing file deletion",
  "windows": [
    "main"
  ],
  "permissions": [
    "fs:default",
    "fs:allow-remove", 
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        "**/*",
        "/**",
        "$HOME/**",
        "$HOME/.*/**"
      ]
    },
        {
      "identifier": "fs:allow-remove",
      "allow": [
        "**/*",
        "/**",
        "$HOME/**",
        "$HOME/.*/**"
      ]
    },
        {
      "identifier": "fs:allow-exists",
      "allow": [
        "**/*",
        "/**",
        "$HOME/**",
        "$HOME/.*/**"
      ]
    }
  ]
}